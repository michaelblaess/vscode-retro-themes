    "statusBar.background": "#0F1B0F",
    "statusBar.foreground": "#33FF33",
    "statusBar.border": "#1E2A1E",
    "statusBar.debuggingBackground": "#FFAA00",
    "statusBar.debuggingForeground": "#000000",
    "statusBar.noFolderBackground": "#051105",
    "tab.activeBackground": "#0A0A0A",
    "tab.activeForeground": "#33FF33",
