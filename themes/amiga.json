    "panelTitle.inactiveForeground": "#FFFFFF80",
    "terminal.background": "#0055AA",
    "terminal.foreground": "#FFFFFF",
    "terminalCursor.foreground": "#FF8800",
    "input.background": "#004BA0",
    "input.foreground": "#FFFFFF",
    "input.border": "#0F53A8",
