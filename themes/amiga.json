    "list.hoverBackground": "#FF880015",
    "list.focusOutline": "#FF8800",
    "list.highlightForeground": "#FF8800",
    "statusBar.background": "#004499",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.border": "#0F53A8",
