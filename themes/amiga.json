    "diffEditor.removedTextBackground": "#FF444420",
    "merge.currentHeaderBackground": "#44BB4440",
    "merge.incomingHeaderBackground": "#FF880040",
    "notifications.background": "#0066BB",
    "notifications.foreground": "#FFFFFF",
